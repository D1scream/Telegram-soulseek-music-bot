# Учётная запись Soulseek (slsknet.org)
SLSKD_SLSK_USERNAME=your_soulseek_username
SLSKD_SLSK_PASSWORD=your_soulseek_password

# Папка на хосте
SLSKD_SHARED_DIRECTORY=C:/Sync — копия/Music

# Скачивание в Telegram (/download) — тот же секрет, что SLSKD_WEBHOOK_SECRET в .env бота
SLSKD_WEBHOOK_SECRET=your-webhook-secret
