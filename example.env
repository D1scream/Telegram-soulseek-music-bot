# --- Поиск музыки /find (опционально) ---
# cp docker/slskd/example.env docker/slskd/.env  — логин/пароль Soulseek
# docker compose -f docker/slskd/docker-compose.yml up -d
# http://localhost:5030 — web UI
# SLSKD_URL=http://localhost:5030
# SLSKD_SEARCH_FILE_LIMIT=50
# SLSKD_SEARCH_DISPLAY_LIMIT=5
# SLSKD_ALLOWED_FORMATS=mp3,flac,ogg,wav,m4a,aac,webm
# UPLOADED_MUSIC_DIR=uploaded_music

